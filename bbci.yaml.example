# bb-crypto-inventory configuration
agent:
  # OpenAI-compatible model to use for the LLM agent
  model: "gpt-4o"
  # API base URL (optional, defaults to OpenAI)
  # api_base: "https://api.openai.com/v1"
  # Maximum Plan-Act-Observe iterations before stopping
  max_iterations: 5
  # Overall timeout in minutes
  timeout_minutes: 30
  # Temperature for LLM responses (lower = more deterministic)
  temperature: 0.1

scan:
  # Which phases to run (0=Recon, 1=Protocol, 2=Application, 3=Oracle/Timing)
  phases: [0, 1, 2, 3]
  # Minimum confidence score to include in final report
  min_confidence: 0.5
  # Enable slow-pace mode for WAF/rate-limit evasion
  slow_pace: false
  # Delay between requests in slow-pace mode (seconds)
  slow_pace_delay: 2.0
  # Max tokens to collect for CH6 randomness testing (default: 200, fast: 100, deep: 2000)
  max_tokens: 200
  # Max randomness tier to run (1=fast, 2=standard, 3=deep)
  # Tier 1: Diff analysis + Permutation Entropy (N≥50)
  # Tier 2: SHR entropy + Anderson-Darling + χ² + Collision (N≥100)
  # Tier 3: SPRT + Min-Entropy + Maurer's Universal Test (N≥200)
  max_randomness_tier: 2
  # Number of measurements for timing analysis
  timing_measurements: 5000

output:
  # Output format: cyclonedx | json | markdown
  format: "cyclonedx"
  # Include raw evidence in output
  include_evidence: true
  # Include LLM-generated remediation suggestions
  include_remediation: true
  # Pretty-print JSON output
  pretty: true
